<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>KyoProject — Profil Perusahaan</title>
  <link rel="stylesheet" href="style.css" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;900&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- NAVBAR -->
  <nav id="navbar">
    <div class="nav-container">
      <div class="logo">KYO<span>PROJECT</span></div>
      <ul class="nav-links">
        <li><a href="#home">Beranda</a></li>
        <li><a href="#about">Tentang</a></li>
        <li><a href="#services">Layanan</a></li>
        <li><a href="#stats">Statistik</a></li>
        <li><a href="#contact">Kontak</a></li>
      </ul>
      <button class="hamburger" id="hamburger" aria-label="Buka menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <!-- HERO -->
  <section id="home" class="hero">
    <div class="hero-bg"></div>
    <div class="hero-content">
      <p class="hero-tag">— Berinovasi untuk Masa Depan</p>
      <h1>Kami Membangun <span>Solusi</span><br/>Digital Terbaik</h1>
      <p class="hero-sub">Mengubah ide menjadi produk andal yang mendorong pertumbuhan, efisiensi, dan dampak nyata bagi bisnis di seluruh dunia.</p>
      <div class="hero-buttons">
        <a href="#services" class="btn btn-primary">Layanan Kami</a>
        <a href="#contact" class="btn btn-outline">Hubungi Kami</a>
      </div>
    </div>
    <div class="hero-graphic">
      <div class="circle c1"></div>
      <div class="circle c2"></div>
      <div class="circle c3"></div>
    </div>
    <div class="scroll-indicator">
      <span></span>
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about" class="about section">
    <div class="container">
      <div class="about-grid">
        <div class="about-visual">
          <div class="about-img-wrap">
            <div class="about-img-block"></div>
            <div class="about-badge">
              <span class="badge-num">5+</span>
              <span class="badge-txt">Tahun Pengalaman</span>
            </div>
          </div>
        </div>
        <div class="about-text">
          <p class="section-label">Tentang Kami</p>
          <h2>Warisan <span>Inovasi</span> Kami</h2>
          <p>Didirikan pada tahun 2020, KyoProject Adalah Jasa Layanan Website Untuk Membantu Umkm di Indonesia Yang Masih Membutuhkan Dukungan Dari Media Sosial Maupun Offline.</p>
          <p>KyoProject memberikan layanan yang memuaskan bagi para konsumen </p>
          <div class="about-values">
            <div class="value-item">
              <div class="value-icon">⚡</div>
              <div>
                <strong>Gesit &amp; Cepat</strong>
                <p>Kami bergerak cepat tanpa mengorbankan kualitas.</p>
              </div>
            </div>
            <div class="value-item">
              <div class="value-icon">🔒</div>
              <div>
                <strong>Andal & Aman</strong>
                <p>Keamanan dan kepercayaan adalah fondasi dari semua yang kami lakukan.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section id="services" class="services section dark-section">
    <div class="container">
      <div class="section-header">
        <p class="section-label">Yang Kami Kerjakan</p>
        <h2>Layanan <span>Unggulan</span> Kami</h2>
        <p class="section-desc">Kami menawarkan solusi digital menyeluruh yang disesuaikan dengan kebutuhan bisnis Anda.</p>
      </div>
      <div class="services-grid">
        <div class="service-card" data-delay="0">
          <div class="service-icon">💻</div>
          <h3>Pengembangan Web Landing Page</h3>
          <p>KyoProject Menawarkan Pembuatan Landing Page Untuk Promosi Bisnis Anda di Mdia Sosial Dan agar Website Anda Terlihat Profesional </p>
          <a href="#contact" class="service-link">Pelajari lebih lanjut →</a>
        </div>
        <div class="service-card" data-delay="100">
          <div class="service-icon">☁️</div>
          <h3>Company Profile</h3>
          <p>Kami Juga menyedakan Pembuatan Website Company Profile Untuk Nama Bisnis Anda Agar lebih Dikenal.</p>
          <a href="#contact" class="service-link">Pelajari lebih lanjut →</a>
        </div>
        <div class="service-card" data-delay="200">
          <div class="service-icon">📊</div>
          <h3>Website Organisasi</h3>
          <p>Kami Juga Menyediakan Website Untuk Organisasi Agar dapat Mempublikasikan Kegiatan Keorganisasian Lewat Website</p>
          <a href="#contact" class="service-link">Pelajari lebih lanjut →</a>
        </div>
        <div class="service-card" data-delay="300">
          <div class="service-icon">🎨</div>
          <h3>Blog Pribadi</h3>
          <p>KyoProject Juga Menawarkan Pembuatan Blog Untuk Kalian Yang Gemar Menulis dan Membuat Artikel</p>
          <a href="#contact" class="service-link">Pelajari lebih lanjut →</a>
        </div>
        <div class="service-card" data-delay="400">
          <div class="service-icon">🔐</div>
          <h3></h3>
          <p>Audit keamanan komprehensif, deteksi ancaman, dan strategi perlindungan menyeluruh.</p>
          <a href="#contact" class="service-link">Pelajari lebih lanjut →</a>
        </div>
        <div class="service-card" data-delay="500">
          <div class="service-icon">🤖</div>
          <h3>AI &amp; Otomasi</h3>
          <p>Solusi otomasi cerdas yang menyederhanakan operasional dan menekan biaya secara signifikan.</p>
          <a href="#contact" class="service-link">Pelajari lebih lanjut →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section id="stats" class="stats section">
    <div class="container">
      <div class="stats-grid">
        <div class="stat-item" data-target="100">
          <span class="stat-num" data-target="100">0</span><span class="stat-suffix">+</span>
          <p>Proyek Selesai</p>
        </div>
        <div class="stat-item" data-target="1">
          <span class="stat-num" data-target="1">0</span><span class="stat-suffix">+</span>
          <p>Anggota Tim</p>
        </div>
        <div class="stat-item" data-target="1">
          <span class="stat-num" data-target="1">0</span><span class="stat-suffix">+</span>
          <p>Negara Dilayani</p>
        </div>
        <div class="stat-item" data-target="98">
          <span class="stat-num" data-target="98">0</span><span class="stat-suffix">%</span>
          <p>Kepuasan Klien</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact" class="contact section">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-info">
          <p class="section-label">Hubungi Kami</p>
          <h2>Mari Bangun Sesuatu yang <span>Hebat</span></h2>
          <p>Siap membawa bisnis Anda ke level berikutnya? Kami ingin mendengar tentang proyek Anda.</p>
          <ul class="contact-details">
            <li><span class="ci-icon">📍</span> Jl.Sendang Utara III.Kot Semarang/li>
            <li><span class="ci-icon">📞</span> +62 88213015446</li>
            <li><span class="ci-icon">✉️</span> kyowebproject@Gmail.com</li>
          </ul>
        </div>
        <form class="contact-form" id="contactForm">
          <div class="form-row">
            <input type="text" placeholder="Nama Anda" required />
            <input type="email" placeholder="Alamat Email" required />
          </div>
          <input type="text" placeholder="Subjek" />
          <textarea placeholder="Ceritakan tentang proyek Anda..." rows="5" required></textarea>
          <button type="submit" class="btn btn-primary btn-full">Kirim Pesan</button>
          <p class="form-success" id="formSuccess">Pesan terkirim! Kami akan segera menghubungi Anda.</p>
        </form>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container">
      <div class="footer-top">
        <div class="footer-brand">
          <div class="logo">KYO<span>PROJECT</span></div>
          <p>Membangun masa depan, satu solusi pada satu waktu.</p>
        </div>
        <div class="footer-links">
          <div class="footer-col">
            <h4>Perusahaan</h4>
            <ul>
              <li><a href="#about">Tentang Kami</a></li>
              <li><a href="#team">Tim Kami</a></li>
              <li><a href="#services">Layanan</a></li>
            </ul>
          </div>
          <div class="footer-col">
            <h4>Terhubung</h4>
            <ul>
              <li><a href="#">Intagram</a></li>
              <li><a href="#">Twitter / X</a></li>
              <li><a href="#">TikTok</a></li>
            </ul>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <p>© 2024 KYOPROJECT. Semua hak dilindungi.</p>
        <p>Dibuat dengan ❤️</p>
      </div>
    </div>
  </footer>

  <script src="script.js"></script>
</body>
</html>
